@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<section class="rg-hero">
    <div class="rg-hero-overlay"></div>
    <div class="container rg-hero-content text-center text-white">
        <h1 class="display-4 fw-bold mb-3">Drive Ghana Your Way</h1>
        <p class="lead mb-4">Premium car rentals in Accra, Kumasi, and Takoradi.<br class="d-none d-md-block"/>Flexible bookings, no hidden fees.</p>

        <!-- Quick Search -->
        <div class="rg-search-card mx-auto">
            <form method="get" asp-page="/Cars/Index" class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small fw-semibold text-dark">Pick-up Date</label>
                    <input type="date" name="start" class="form-control"
                           min="@DateTime.Today.ToString("yyyy-MM-dd")"
                           value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-semibold text-dark">Return Date</label>
                    <input type="date" name="end" class="form-control"
                           min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")"
                           value="@DateTime.Today.AddDays(3).ToString("yyyy-MM-dd")" required />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn rg-btn-primary w-100">
                        <i class="bi bi-search"></i> Search Cars
                    </button>
                </div>
            </form>
        </div>
    </div>
</section>

<!-- Trust Badges -->
<section class="py-4 bg-light border-bottom">
    <div class="container">
        <div class="row text-center g-3">
            <div class="col-6 col-md-3">
                <i class="bi bi-shield-check fs-3 text-success"></i>
                <p class="small mb-0 mt-1 fw-semibold">Insured Fleet</p>
            </div>
            <div class="col-6 col-md-3">
                <i class="bi bi-clock fs-3 text-success"></i>
                <p class="small mb-0 mt-1 fw-semibold">24/7 Support</p>
            </div>
            <div class="col-6 col-md-3">
                <i class="bi bi-cash-stack fs-3 text-success"></i>
                <p class="small mb-0 mt-1 fw-semibold">No Hidden Fees</p>
            </div>
            <div class="col-6 col-md-3">
                <i class="bi bi-geo-alt fs-3 text-success"></i>
                <p class="small mb-0 mt-1 fw-semibold">Multiple Locations</p>
            </div>
        </div>
    </div>
</section>

<!-- Featured Cars -->
<section class="py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold mb-1">Featured Vehicles</h2>
                <p class="text-muted mb-0">Hand-picked for your journey</p>
            </div>
            <a asp-page="/Cars/Index" class="btn rg-btn-outline d-none d-md-inline-flex">
                View All <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>

        <div class="row g-4">
            @foreach (var car in Model.FeaturedCars)
            {
                <div class="col-sm-6 col-lg-4">
                    <div class="card rg-car-card h-100">
                        <div class="rg-car-img-wrapper">
                            <img src="@car.ImagePath" alt="@car.Make @car.Model"
                                 class="card-img-top rg-car-img"
                                 onerror="this.src='/images/cars/placeholder.svg'" />
                            <span class="badge rg-badge-category">@car.Category</span>
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title mb-1">@car.Year @car.Make @car.Model</h5>
                            <p class="text-muted small mb-2">
                                <i class="bi bi-geo-alt"></i> @car.Location
                            </p>
                            <p class="card-text text-muted small flex-grow-1">@car.Description</p>
                            <div class="d-flex gap-3 text-muted small mb-3">
                                <span><i class="bi bi-people"></i> @car.Seats seats</span>
                                <span><i class="bi bi-gear"></i> @car.Transmission</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="fs-5 fw-bold text-success">GHS @car.DailyRate.ToString("N0")</span>
                                    <span class="text-muted small">/day</span>
                                </div>
                                <a asp-page="/Cars/Book" asp-route-id="@car.Id" class="btn rg-btn-primary btn-sm">
                                    Book Now
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="text-center mt-4 d-md-none">
            <a asp-page="/Cars/Index" class="btn rg-btn-outline">View All Cars</a>
        </div>
    </div>
</section>

<!-- How It Works -->
<section class="py-5 bg-light">
    <div class="container text-center">
        <h2 class="fw-bold mb-2">How It Works</h2>
        <p class="text-muted mb-5">Book your car in 3 simple steps</p>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="rg-step-circle mx-auto mb-3">1</div>
                <h5 class="fw-semibold">Choose Your Car</h5>
                <p class="text-muted small">Browse our fleet and select the perfect vehicle for your trip.</p>
            </div>
            <div class="col-md-4">
                <div class="rg-step-circle mx-auto mb-3">2</div>
                <h5 class="fw-semibold">Pick Your Dates</h5>
                <p class="text-muted small">Select pick-up and return dates. No surprise fees.</p>
            </div>
            <div class="col-md-4">
                <div class="rg-step-circle mx-auto mb-3">3</div>
                <h5 class="fw-semibold">Pay &amp; Drive</h5>
                <p class="text-muted small">Secure payment, instant confirmation, and you're on the road.</p>
            </div>
        </div>
    </div>
</section>
