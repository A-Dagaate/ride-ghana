@page
@model RideGhana.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "_Layout";
}

<div class="container py-5" style="max-width:450px">
    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <h2 class="fw-bold text-center mb-1">Welcome back</h2>
            <p class="text-center text-muted mb-4">Sign in to your Ride Ghana account</p>

            <form method="post">
                <input type="hidden" asp-for="ReturnUrl" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:none"></div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Email address</label>
                    <input asp-for="Input.Email" type="email" class="form-control form-control-lg" placeholder="you@example.com" autofocus />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Password</label>
                    <input asp-for="Input.Password" type="password" class="form-control form-control-lg" placeholder="••••••••" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="mb-4 d-flex justify-content-between align-items-center">
                    <div class="form-check">
                        <input asp-for="Input.RememberMe" class="form-check-input" type="checkbox" />
                        <label class="form-check-label small" asp-for="Input.RememberMe">Remember me</label>
                    </div>
                </div>

                <div class="d-grid mb-3">
                    <button type="submit" class="btn rg-btn-primary btn-lg">Sign In</button>
                </div>
            </form>

            <p class="text-center text-muted small mb-0">
                Don't have an account? <a asp-page="/Account/Register" class="text-success fw-semibold">Sign up</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
}
