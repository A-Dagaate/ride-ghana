@page
@model RideGhana.Pages.Cars.IndexModel
@{
    ViewData["Title"] = "Browse Cars";
}

<div class="container py-5">
    <h2 class="fw-bold mb-1">Available Cars</h2>
    <p class="text-muted mb-4">
        Showing availability from <strong>@Model.Start.ToString("MMM d")</strong>
        to <strong>@Model.End.ToString("MMM d, yyyy")</strong>
    </p>

    <!-- Date Filter -->
    <div class="card rg-filter-card mb-4">
        <div class="card-body">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-sm-4">
                    <label class="form-label small fw-semibold">Pick-up Date</label>
                    <input type="date" name="start" class="form-control"
                           value="@Model.Start.ToString("yyyy-MM-dd")"
                           min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-sm-4">
                    <label class="form-label small fw-semibold">Return Date</label>
                    <input type="date" name="end" class="form-control"
                           value="@Model.End.ToString("yyyy-MM-dd")"
                           min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-sm-4">
                    <button type="submit" class="btn rg-btn-primary w-100">
                        <i class="bi bi-search"></i> Update Search
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Cars.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-car-front fs-1 text-muted"></i>
            <h5 class="mt-3 text-muted">No cars available for these dates</h5>
            <p class="text-muted">Try adjusting your dates.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var car in Model.Cars)
            {
                <div class="col-sm-6 col-lg-4">
                    <div class="card rg-car-card h-100">
                        @{ var isComingSoon = car.Make == "Mercedes-Benz" || (car.Make == "Hyundai" && car.Model == "Tucson") || (car.Make == "Kia" && car.Model == "Rio"); }
                        <div class="rg-car-img-wrapper">
                            <img src="@car.ImagePath" alt="@car.Make @car.Model"
                                 class="card-img-top rg-car-img"
                                 onerror="this.src='/images/cars/placeholder.svg'" />
                            <span class="badge rg-badge-category">@car.Category</span>
                            @if (isComingSoon)
                            {
                                <div class="rg-coming-soon-banner">Coming Soon</div>
                            }
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title mb-1">@car.Year @car.Make @car.Model</h5>
                            <p class="text-muted small mb-2"><i class="bi bi-geo-alt"></i> @car.Location</p>
                            <p class="card-text text-muted small flex-grow-1">@car.Description</p>
                            <div class="d-flex gap-3 text-muted small mb-3">
                                <span><i class="bi bi-people"></i> @car.Seats seats</span>
                                <span><i class="bi bi-gear"></i> @car.Transmission</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="fs-5 fw-bold text-success" data-ghs="@car.DailyRate">GHS @car.DailyRate.ToString("N0")</span>
                                    <span class="text-muted small">/day</span>
                                </div>
                                @if (isComingSoon)
                                {
                                    <button class="btn btn-secondary btn-sm" disabled>Coming Soon</button>
                                }
                                else
                                {
                                    <a asp-page="/Cars/Book"
                                       asp-route-id="@car.Id"
                                       asp-route-start="@Model.Start.ToString("yyyy-MM-dd")"
                                       asp-route-end="@Model.End.ToString("yyyy-MM-dd")"
                                       class="btn rg-btn-primary btn-sm">
                                        Book Now
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
