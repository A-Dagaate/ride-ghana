@inject Microsoft.Extensions.Configuration.IConfiguration _cfg
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#1a7a4a" />
    <title>@ViewData["Title"] - Ride Ghana</title>

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/images/icon-192.png" />

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- Custom -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Expose exchange rate to JS -->
    <script>window.RG_GHS_TO_USD = @_cfg["ExchangeRate:GhsToUsd"];</script>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg rg-navbar sticky-top">
        <div class="container">
            <a class="navbar-brand" asp-page="/Index">
                <span class="rg-logo">🚗 Ride Ghana</span>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navMenu" aria-controls="navMenu" aria-expanded="false">
                <i class="bi bi-list fs-2 text-white"></i>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Cars/Index">Browse Cars</a>
                    </li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Admin</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-page="/Admin/Cars/Index">Manage Fleet</a></li>
                                <li><a class="dropdown-item" asp-page="/Admin/Reservations/Index">All Reservations</a></li>
                            </ul>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav ms-auto align-items-center">

                    <!-- Currency Toggle -->
                    <li class="nav-item me-2">
                        <button id="currencyToggle" class="rg-currency-toggle" onclick="RG.toggleCurrency()" title="Switch currency">
                            <span class="rg-currency-option" id="optGhs">GHS</span>
                            <span class="rg-currency-divider">|</span>
                            <span class="rg-currency-option" id="optUsd">USD</span>
                        </button>
                    </li>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Reservations/Index">
                                <i class="bi bi-calendar-check"></i> My Bookings
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i> @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <form method="post" asp-page="/Account/Logout">
                                        <button type="submit" class="dropdown-item">
                                            <i class="bi bi-box-arrow-right"></i> Sign Out
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Account/Login">Sign In</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn rg-btn-outline ms-2" asp-page="/Account/Register">Sign Up</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Flash Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible m-0 rounded-0" role="alert">
            <div class="container"><i class="bi bi-check-circle"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible m-0 rounded-0" role="alert">
            <div class="container"><i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        </div>
    }

    <main>
        @RenderBody()
    </main>

    <footer class="rg-footer mt-5">
        <div class="container py-4">
            <div class="row g-4">
                <div class="col-md-4">
                    <h5 class="text-white">🚗 Ride Ghana</h5>
                    <p class="text-muted small">Premium car rentals across Ghana. Safe, reliable, affordable.</p>
                </div>
                <div class="col-md-4">
                    <h6 class="text-white">Quick Links</h6>
                    <ul class="list-unstyled small">
                        <li><a class="text-muted text-decoration-none" asp-page="/Cars/Index">Browse Cars</a></li>
                        <li><a class="text-muted text-decoration-none" asp-page="/Account/Register">Create Account</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="text-white">Contact</h6>
                    <p class="text-muted small">
                        <i class="bi bi-envelope"></i> support@rideghana.com<br/>
                        <i class="bi bi-geo-alt"></i> Accra, Ghana
                    </p>
                </div>
            </div>
            <hr class="border-secondary" />
            <p class="text-center text-muted small mb-0">&copy; @DateTime.Now.Year Ride Ghana. All rights reserved.</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
